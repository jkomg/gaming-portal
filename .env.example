# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development

# Database
# SQLite (local dev — default when DATABASE_URL is omitted)
# DATABASE_URL=sqlite:///data/db.sqlite
#
# Turso (production)
# DATABASE_URL=libsql+https://<db-name>.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# Discord OAuth2
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Comma-separated Discord user IDs that get staff access
ALLOWED_DISCORD_IDS=

# Notion (optional — only needed if using Notion sync)
# NOTION_TOKEN=secret_...

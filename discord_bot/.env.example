# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (same Turso DB as the Cloud Run portal) ─────────────────────────
DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=

# ── Portal ────────────────────────────────────────────────────────────────────
PORTAL_URL=https://gaming.jkomg.us

# ── Whisper model ─────────────────────────────────────────────────────────────
# tiny / base / small / medium / large-v3
WHISPER_MODEL=medium
WHISPER_DEVICE=auto
WHISPER_COMPUTE=default

# ── Internal ──────────────────────────────────────────────────────────────────
STATUS_PORT=8765
